{
  "name": "kinetex",
  "version": "1.0.0",
  "description": "Seven production-ready Cloudflare Workers showcasing kinetex v0.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-kinetex.mjs",
    "dev":         "wrangler dev src/index.ts",
    "deploy":      "wrangler deploy src/index.ts",
    "types":       "wrangler types",
    "typecheck":   "tsc --noEmit",
    "cf:login":    "wrangler login",
    "cf:whoami":   "wrangler whoami"
  },
  "dependencies": {
    "kinetex":           "0.0.2",
    "undici":            "^7.24.6",
    "zod":               "^4.3.6",
    "valibot":           "^1.3.1",
    "socks-proxy-agent": "^10.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "typescript":                "^5.8.3",
    "wrangler":                  "^4.79.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
